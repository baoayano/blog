---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import Footer from "../components/Footer.astro";

const posts = await getCollection("blog");
posts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
---

<Layout>
	<!-- Hero Section -->
	<section class="py-12 flex items-center gap-x-8 gap-y-8 flex-col lg:flex-row">
		<img src="/homura.png" alt="Homura" class="w-[230px] h-[205.8px]" />

		<div>
			<h1 class="text-3xl lg:text-4xl font-bold mb-4 text-center lg:text-left">Welcome to Ari's Blog</h1>
			<p class="text-base lg:text-lg opacity-80 text-center lg:text-left max-w-xl lg:max-w-none">
				This is a blog about my journey learning web development,
				sharing tips, and exploring new technologies. Stay tuned for
				updates and feel free to reach out if you have any questions or
				suggestions!
			</p>

			<div class="mt-8 lg:mt-4 flex gap-x-4 justify-center lg:justify-start">
				<a
					href="https://github.com/baoayano"
					target="_blank"
					rel="noopener noreferrer"
				>
					<Icon name="mdi:github" class="w-10 h-10" />
				</a>

				<a
					href="https://twitter.com/hayakawa_ayano"
					target="_blank"
					rel="noopener noreferrer"
				>
					<Icon name="ri:twitter-x-line" class="w-10 h-10" />
				</a>
			</div>
		</div>
	</section>

	<!-- Recent Posts -->
	<section class="py-12">
		<h2 class="text-2xl lg:text-3xl font-semibold mb-6">Recent Posts</h2>
		<div class="grid gap-6 md:grid-cols-2">
			{
				posts.slice(0, 4).map((post: any) => (
					<a href={`/blog/${post.id}`} class="block group">
						<div class="overflow-hidden rounded-lg w-full h-[230px]">
							<img
								src={post.data.cover}
								alt="Post Cover"
								class="w-full h-full object-cover rounded-lg group-hover:scale-110 transition-transform duration-300"
							/>
						</div>
						<div>
							<h3 class="text-xl font-semibold mt-4 group-hover:underline">
								{post.data.title}
							</h3>
							<p class="text-sm opacity-80 mt-1">
								Published on{" "}
								{new Date(post.data.pubDate).toLocaleDateString("en-US", {
									year: "numeric",
									month: "long",
									day: "numeric",
								})}
							</p>
						</div>
					</a>
				))
			}
		</div>
</Layout>

<Footer />
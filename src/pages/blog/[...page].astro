---
// Importing necessary components and functions
import Layout from "../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

// Type definition for blog posts
import type { Blog } from "../../utils/interface";
import type { GetStaticPathsOptions } from "astro";

// Generating static paths for pagination based on the total number of blog posts
export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const posts = await getCollection("blog");
    posts.sort(
        (a, b) =>
            new Date(b.data.pubDate).getTime() -
            new Date(a.data.pubDate).getTime(),
    );

    if (posts.length === 0) {
        return [];
    }

    return paginate(posts, {
        pageSize: 5,
    });
}

const { page } = Astro.props as {
    page: { data: Blog[]; currentPage: number; total: number };
};

const pageSize = 5;
const totalPages = Math.ceil(page.total / pageSize);
const previousPage = page.currentPage > 1 ? page.currentPage - 1 : null;
const nextPage = page.currentPage < totalPages ? page.currentPage + 1 : null;

const getPageHref = (pageNumber: number) =>
    pageNumber === 1 ? "/blog" : `/blog/${pageNumber}`;
---

<Layout
    title="Blog | Ari's Blog"
    description="Explore my latest blog posts."
>
    <div class="pt-12 pb-3">
        <h1 class="text-3xl lg:text-4xl font-bold mb-6">Blog</h1>
        <p class="text-base lg:text-lg opacity-80 mb-8">
            Umm... Welcome to my blog! I'm still working on it, but feel free to
            check back later for updates and new posts.
        </p>
    </div>

    <div class="flex flex-col gap-y-6">
        {
            page.data.map((post: Blog) => (
                <a href={`/blog/${post.id}`} class="block flex flex-col lg:flex-row gap-x-6 group">
                    <div class="overflow-hidden rounded-lg w-full max-h-[200px] sm:max-h-[350px] md:max-h-[380px] lg:w-[330px] lg:max-h-[160px]">
                        <img
                            src={post.data.cover.src}
                            alt="Post Cover"
                            class="w-full h-full aspect-auto object-cover rounded-lg group-hover:scale-110 transition-transform duration-300"
                        />
                    </div>
                    <div class="flex-1 relative mt-4 lg:mt-0">
                        <h3 class="text-xl lg:text-2xl font-semibold group-hover:underline">
                            {post.data.title}
                        </h3>
                        <p class="text-sm lg:text-base opacity-80 lg:mt-1 mt-2">
                            {
                                // limit description to 100 characters
                                post.data.description.length > 300
                                    ? post.data.description.slice(0, 300) + "..."
                                    : post.data.description
                            }
                        </p>
                        <p class="text-sm opacity-80 mt-4 lg:mt-0 lg:absolute bottom-0">
                            <span class="hidden lg:inline-block">Published on{" "}</span>
                            {new Date(post.data.pubDate).toLocaleDateString("en-US", {
                                year: "numeric",
                                month: "long",
                                day: "numeric",
                            })}
                        </p>
                    </div>
                </a>
            ))
        }

        {
            totalPages > 1 && (
                <nav
                    aria-label="Blog pagination"
                    class="mx-auto mt-12 pb-12 flex items-center gap-x-4"
                >
                    {
                        previousPage ? (
                            <a
                                href={getPageHref(previousPage)}
                                aria-label="Previous page"
                                class="rounded-md opacity-80 hover:opacity-100 transition-opacity cursor-pointer"
                            >
                                <Icon name="mdi:chevron-left" class="w-12 h-12 inline-block" />
                            </a>
                        ) : (
                            <span
                                aria-disabled="true"
                                class="rounded-md opacity-30 cursor-not-allowed"
                            >
                                <Icon name="mdi:chevron-left" class="w-12 h-12 inline-block" />
                            </span>
                        )
                    }

                    <span class="text-sm opacity-80">
                        Page {page.currentPage} of {totalPages}
                    </span>

                    {
                        nextPage ? (
                            <a
                                href={getPageHref(nextPage)}
                                aria-label="Next page"
                                class="rounded-md opacity-80 hover:opacity-100 transition-opacity cursor-pointer"
                            >
                                <Icon name="mdi:chevron-right" class="w-12 h-12 inline-block" />
                            </a>
                        ) : (
                            <span
                                aria-disabled="true"
                                class="rounded-md opacity-30 cursor-not-allowed"
                            >
                                <Icon name="mdi:chevron-right" class="w-12 h-12 inline-block" />
                            </span>
                        )
                    }
                </nav>
            )
        }
    </div>
</Layout>

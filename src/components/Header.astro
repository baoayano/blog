---
import { Icon } from "astro-icon/components";
---

<div id="navigation">
    <div
        class="container mx-auto flex items-center justify-between px-3 py-3 lg:py-6"
    >
        <div class="flex gap-x-4 items-center">
            <a
                href="/"
                class="font-semibold text-lg opacity-80 hover:opacity-100 transition-opacity"
                >Home</a
            >
            <a
                href="/blog"
                class="font-semibold text-lg opacity-80 hover:opacity-100 transition-opacity"
                >Blog</a
            >
        </div>

        <div class="ml-auto flex gap-x-4 items-center">
            <a href="#" id="themeToggle">
                <Icon
                    name="ri:sun-fill"
                    class="w-7 h-7 hidden"
                    id="light-icon"
                />
                <Icon
                    name="ri:moon-clear-fill"
                    class="w-7 h-7 hidden"
                    id="dark-icon"
                />
            </a>
        </div>
    </div>
</div>

<script src="../utils/theme.ts"></script>

<script>
    const navigation = document.getElementById("navigation");

    const navigationEntry =
        window.performance.getEntriesByType("navigation")[0] as PerformanceNavigationTiming | undefined;
    const statusCode = navigationEntry
        ? navigationEntry.responseStatus
        : "Unknown";

    // scroll event
    window.addEventListener("scroll", () => {
        if (navigation && statusCode === 200) {
            if (window.scrollY > 50) {
                navigation.classList.add(
                    "fixed",
                    "top-0",
                    "left-0",
                    "w-full",
                    "bg-[#ffffff85]",
                    "dark:bg-[#0d090a85]",
                    "shadow-md",
                    "z-50",
                    "backdrop-blur-md",
                );
            } else {
                navigation.classList.remove(
                    "fixed",
                    "top-0",
                    "left-0",
                    "w-full",
                    "bg-[#ffffff85]",
                    "dark:bg-[#0d090a85]",
                    "shadow-md",
                    "z-50",
                    "backdrop-blur-md",
                );
            }
        }
    });

    window.addEventListener("load", () => {
        if (navigation) {
            if (window.scrollY > 50 || statusCode !== 200) {
                navigation.classList.add(
                    "fixed",
                    "top-0",
                    "left-0",
                    "w-full",
                    "bg-[#ffffff85]",
                    "dark:bg-[#0d090a85]",
                    statusCode === 200 ? "shadow-md" : "shadow-none",
                    "z-50",
                    "backdrop-blur-md",
                );
            } else {
                navigation.classList.remove(
                    "fixed",
                    "top-0",
                    "left-0",
                    "w-full",
                    "bg-[#ffffff85]",
                    "dark:bg-[#0d090a85]",
                    "shadow-md",
                    "z-50",
                    "backdrop-blur-md",
                );
            }
        }
    });
</script>
